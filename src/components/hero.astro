---
const images = [
    { src: "/img/hero-1.png", alt: "Davao del Sur View 1" },
    { src: "/img/hero-2.png", alt: "Davao del Sur View 2" },
    { src: "/img/hero-3.png", alt: "Davao del Sur View 3" },
];
---

<section class="relative h-[75vh] w-full overflow-hidden bg-slate-900 group">
    <div
        id="hero-slider"
        class="flex w-[300%] h-full transition-transform duration-700 ease-[cubic-bezier(0.8,0,0.2,1)]"
    >
        {
            images.map((img) => (
                <img
                    src={img.src}
                    class="w-1/3 h-full object-cover"
                    alt={img.alt}
                />
            ))
        }
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-30">
        {
            images.map((_, i) => (
                <button
                    data-index={i}
                    class="nav-dot w-3 h-3 rounded-full border-2 border-white/50 transition-all duration-300 hover:bg-white focus:outline-none"
                    aria-label={`Go to slide ${i + 1}`}
                />
            ))
        }
    </div>

    <div
        class="absolute inset-0 bg-black/40 flex items-center justify-center pointer-events-none"
    >
        <div class="text-center px-4">
            <h1
                class="text-white text-5xl md:text-7xl font-bold drop-shadow-2xl"
            >
                Sangguniang Kabataan
            </h1>
            <p
                class="text-white/90 text-lg md:text-xl font-normal tracking-[0.3em] uppercase mt-4"
            >
                Provincial Federation of Davao del Sur
            </p>
        </div>
    </div>
</section>

<style>
    .nav-dot.active {
        background-color: white;
        border-color: white;
        width: 2rem;
    }
</style>

<script>
    const slider = document.getElementById("hero-slider") as HTMLElement;
    const dots = document.querySelectorAll<HTMLButtonElement>(".nav-dot");
    let currentIndex = 0;
    const totalSlides = 3;
    let interval: ReturnType<typeof setInterval>;

    function updateSlider(index: number) {
        currentIndex = index;
        slider.style.transform = `translateX(-${(currentIndex * 100) / totalSlides}%)`;

        dots.forEach((dot, i) => {
            dot.classList.toggle("active", i === currentIndex);
        });
    }

    function startAutoScroll() {
        interval = setInterval(() => {
            currentIndex = (currentIndex + 1) % totalSlides;
            updateSlider(currentIndex);
        }, 5000);
    }

    function resetTimer() {
        clearInterval(interval);
        startAutoScroll();
    }

    dots.forEach((dot) => {
        dot.addEventListener("click", () => {
            const index = parseInt(dot.getAttribute("data-index") ?? "0", 10);
            updateSlider(index);
            resetTimer();
        });
    });

    updateSlider(0);
    startAutoScroll();
</script>