---
const { pathname } = Astro.url;
const currentPath = pathname === "/" ? "/" : pathname.replace(/\/$/, "");

const leftNav = [
  { name: "HOME", href: "/" },
  { name: "GOVERNMENT", href: "/government" },
  { name: "NEWS & EVENTS", href: "/news" },
];

const rightNav = [
  { name: "ABOUT US", href: "/about" },
  { name: "CONTACT US", href: "/contact" },
];
---

<header
  class="w-full bg-[#081740] text-white shadow-md font-sans sticky top-0 z-[100]"
>
  <div class="w-full px-8 h-20 flex items-center justify-between relative">
    <nav class="hidden lg:flex items-center justify-between flex-1 pr-40">
      {
        leftNav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-[13px] tracking-[0.15em] transition-all duration-200 hover:text-white/80 whitespace-nowrap",
              currentPath === item.href ? "font-bold" : "font-normal",
            ]}
          >
            {item.name}
          </a>
        ))
      }
    </nav>

    <div
      class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-[33%] z-[110]"
    >
      <a
        href="/"
        class="block hover:scale-105 transition-transform duration-500 ease-out"
      >
        <img
          src="/img/sk-logo.png"
          alt="SK Logo"
          class="w-40 h-40 md:w-52 md:h-52 object-contain"
        />
      </a>
    </div>

    <nav class="hidden lg:flex items-center flex-1 pl-40">
      <div class="flex items-center justify-between w-full">
        {
          rightNav.map((item) => (
            <a
              href={item.href}
              class:list={[
                "text-[13px] tracking-[0.15em] transition-all duration-200 hover:text-white/80 whitespace-nowrap",
                currentPath === item.href ? "font-bold" : "font-normal",
              ]}
            >
              {item.name}
            </a>
          ))
        }

        <button
          class="flex items-center gap-2 hover:opacity-70 transition-opacity ml-8 group"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover:scale-110 transition-transform"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <span class="text-[13px] font-normal tracking-[0.15em] uppercase"
            >Search</span
          >
        </button>
      </div>
    </nav>
  </div>
</header>
