---
import Featured from './featured.astro';
import Announcement from './announcement.astro';
---

<section class="w-full px-8 lg:px-16 py-12 flex flex-col lg:flex-row gap-8 max-w-[2000px] mx-auto">
    <Featured />
    <Announcement />
</section>

<style is:global>
    .scrollbar-minimal {
        scrollbar-width: auto;
        scrollbar-color: auto;
    }

    .flex.overflow-x-auto {
        padding-bottom: 1rem;
    }
</style>